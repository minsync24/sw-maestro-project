# Local Gemini integration test settings.
# Copy this file to .env and fill values locally. Never commit real secrets.

AI_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AUTOCOIN_AI_RUNS_FILE=.runtime/autocoin-ai-runs.json

# Keep AI Agent standalone tests isolated from Binance execution.
BINANCE_MODE=disabled
