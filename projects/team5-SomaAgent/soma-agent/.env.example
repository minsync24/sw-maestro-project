# =============================================================================
# SomaAgent — 환경 변수 예시. 실제 값은 .env 파일에 저장 (gitignored)
# =============================================================================

# App
APP_ENV=local              # local | dev | prod
APP_PORT=8000
LOG_LEVEL=INFO

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=soma
MYSQL_PASSWORD=somapw
MYSQL_DATABASE=soma_agent

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=soma_chunks

# Upstage Solar (LLM/Embedding)
# 실측: solar-pro는 latest 별칭. embedding은 passage(저장)/query(검색) 분리, 차원 4096.
SOLAR_API_KEY=
SOLAR_LLM_MODEL=solar-pro
SOLAR_EMBEDDING_PASSAGE_MODEL=embedding-passage
SOLAR_EMBEDDING_QUERY_MODEL=embedding-query

# OpenSoma Sidecar (FastAPI 앱이 호출하는 내부 URL)
OPENSOMA_SIDECAR_URL=http://opensoma-sidecar:3000

# Webex (운영자 OAuth Integration 또는 Personal Access Token)
# Scopes: spark:rooms_read spark:messages_read
OPERATOR_WEBEX_TOKEN=
WEBEX_SENDER_SALT=

# Sync schedule (cron expressions)
SYNC_NOTICES_CRON=*/30 * * * *
SYNC_MENTORINGS_CRON=*/30 * * * *
SYNC_WEBEX_CRON=0 * * * *

# Calendar mock
CALENDAR_MOCK_FAIL_RATE=0.0
