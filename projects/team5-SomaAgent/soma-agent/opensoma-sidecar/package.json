{
  "name": "opensoma-sidecar",
  "version": "0.1.0",
  "description": "OpenSoma TS SDK를 HTTP RPC로 노출하는 sidecar (FastAPI 앱이 호출)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "opensoma": "^0.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
